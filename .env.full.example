# ============================================================
# Seahorse Agent 全量部署环境变量
# 复制此文件为 .env：cp .env.full.example .env
# ============================================================

# ========== AI 模型配置（必填）==========
SEAHORSE_AGENT_ADAPTERS_AI_BASE_URL=https://api.openai.com/v1
SEAHORSE_AGENT_ADAPTERS_AI_API_KEY=sk-your-api-key-here
SEAHORSE_AGENT_ADAPTERS_AI_CHAT_MODEL=gpt-4o-mini
SEAHORSE_AGENT_ADAPTERS_AI_EMBEDDING_MODEL=text-embedding-3-small
SEAHORSE_AGENT_ADAPTERS_AI_RERANK_MODEL=

# ========== 数据库 ==========
POSTGRES_DB=seahorse
POSTGRES_USER=seahorse
POSTGRES_PASSWORD=seahorse

# ========== Milvus 向量库 ==========
MILVUS_DIMENSION=1024
MILVUS_METRIC_TYPE=COSINE

# ========== Elasticsearch ==========
ES_JAVA_OPTS=-Xms512m -Xmx512m

# ========== MinIO 对象存储 ==========
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
