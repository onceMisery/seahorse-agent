# ============================================================
# Seahorse Agent 全量部署环境变量
# 复制此文件为 .env：cp .env.full.example .env
# ============================================================

# ========== AI 模型配置（必填）==========
SEAHORSE_AGENT_ADAPTERS_AI_BASE_URL=https://api.openai.com/v1
SEAHORSE_AGENT_ADAPTERS_AI_API_KEY=sk-your-api-key-here
SEAHORSE_AGENT_ADAPTERS_AI_CHAT_MODEL=gpt-4o-mini
SEAHORSE_AGENT_ADAPTERS_AI_EMBEDDING_MODEL=text-embedding-3-small
SEAHORSE_AGENT_ADAPTERS_AI_RERANK_MODEL=

# ========== 数据库 ==========
POSTGRES_DB=seahorse
POSTGRES_USER=seahorse
POSTGRES_PASSWORD=seahorse

# ========== Milvus 向量库 ==========
MILVUS_DIMENSION=1024
MILVUS_METRIC_TYPE=COSINE

# ========== Elasticsearch ==========
ES_JAVA_OPTS=-Xms512m -Xmx512m

# ========== MinIO 对象存储 ==========
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# ========== Product mode / feature capabilities ==========
VITE_SEAHORSE_PRODUCT_MODE=enterprise-platform
VITE_SEAHORSE_ENABLE_ADVANCED_ADMIN=true
SEAHORSE_AGENT_PRODUCT_MODE=enterprise-platform
SEAHORSE_AGENT_ADVANCED_SANDBOX_ENABLED=true
SEAHORSE_AGENT_ADVANCED_CONNECTOR_MANAGEMENT_ENABLED=true
SEAHORSE_AGENT_ADVANCED_MCP_TOOL_ENABLED=true
SEAHORSE_AGENT_ADVANCED_SECRET_MANAGEMENT_ENABLED=true
SEAHORSE_AGENT_ADVANCED_AGENT_HANDOFF_ENABLED=true
SEAHORSE_AGENT_ADVANCED_REMOTE_AGENT_ENABLED=true
SEAHORSE_AGENT_ADVANCED_LOCAL_AGENT_ENABLED=true
SEAHORSE_AGENT_ADVANCED_INTENT_TREE_MANAGEMENT_ENABLED=true
SEAHORSE_AGENT_ADVANCED_INGESTION_TASK_MANAGEMENT_ENABLED=true
SEAHORSE_AGENT_ADVANCED_INGESTION_PIPELINE_MANAGEMENT_ENABLED=true
SEAHORSE_AGENT_ADVANCED_TOOL_CATALOG_MANAGEMENT_ENABLED=true
SEAHORSE_AGENT_ADVANCED_AGENT_DEFINITION_MANAGEMENT_ENABLED=true
SEAHORSE_AGENT_ADVANCED_AGENT_FACTORY_MANAGEMENT_ENABLED=true
SEAHORSE_AGENT_ADVANCED_AGENT_TOOL_BINDING_MANAGEMENT_ENABLED=true
SEAHORSE_AGENT_ADVANCED_AGENT_RUN_MANAGEMENT_ENABLED=true
SEAHORSE_AGENT_ADVANCED_AGENT_EVALUATION_ENABLED=true
SEAHORSE_AGENT_ADVANCED_PRODUCTION_GATE_ENABLED=true
SEAHORSE_AGENT_ADVANCED_ENTERPRISE_PILOT_READINESS_ENABLED=true
SEAHORSE_AGENT_ADVANCED_AGENT_ROLLOUT_MANAGEMENT_ENABLED=true
SEAHORSE_AGENT_ADVANCED_QUOTA_MANAGEMENT_ENABLED=true
SEAHORSE_AGENT_ADVANCED_RESOURCE_ACL_MANAGEMENT_ENABLED=true
SEAHORSE_AGENT_ADVANCED_MEMORY_GOVERNANCE_ENABLED=true
SEAHORSE_AGENT_ADVANCED_RAG_EVALUATION_ENABLED=true
SEAHORSE_AGENT_ADVANCED_METADATA_GOVERNANCE_ENABLED=true
SEAHORSE_AGENT_ADVANCED_AUDIT_LOG_ENABLED=true
SEAHORSE_AGENT_ADVANCED_COST_ANALYTICS_ENABLED=true
